# Database Connection
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# For local development with SQLite (if preferred over Postgres): "file:./dev.db"
#
# IMPORTANT for Vercel/serverless deployments with connection pooler (Supabase, Neon, PgBouncer):
#   - DATABASE_URL should point to the POOLED connection and include ?pgbouncer=true
#     e.g. "postgresql://user:password@pooler.supabase.com:6543/mydb?pgbouncer=true"
#   - DIRECT_URL should point to the DIRECT (non-pooled) connection
#     e.g. "postgresql://user:password@db.supabase.com:5432/mydb"
#   - Without ?pgbouncer=true, Prisma uses prepared statements which conflict
#     with connection poolers in transaction mode, causing:
#     "prepared statement does not exist" errors
DATABASE_URL="postgresql://user:password@localhost:5432/mydb?schema=public"
DIRECT_URL="postgresql://postgres:password@localhost:5432/mydb"

# NextAuth Configuration
# Run `openssl rand -base64 32` to generate a secret
NEXTAUTH_SECRET="changeme_random_string_at_least_32_chars"
NEXTAUTH_URL="http://localhost:3000"

# OAuth Providers (Optional)
# Get these from Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
